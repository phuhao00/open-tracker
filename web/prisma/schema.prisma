generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  passwordHash   String
  image          String?
  skills         String    @default("[]") // JSON string array
  goal           String    @default("quick") // quick | clear | big | learn
  headline       String?
  bio            String?
  aboutLong      String?   // 完整自我介绍
  socialsJson    String    @default("[]") // [{platform,url,label?}]
  videosJson     String    @default("[]") // [{title?,url}]
  availableHours String    @default("flexible") // fulltime | parttime | weekends | flexible
  timezone       String?
  city           String?
  profilePublic  Boolean   @default(true)
  reputation     Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
  shortlists     Shortlist[]
  sources        UserSource[]
  claims         TaskClaim[]
  activities     Activity[]
  earnings       Earning[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BountySource {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  enabled     Boolean  @default(true)
  configJson  String   @default("{}")
  lastSyncAt  DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userLinks   UserSource[]
  tasks       BountyTask[]
}

model UserSource {
  id       String       @id @default(cuid())
  userId   String
  sourceId String
  enabled  Boolean      @default(true)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  source   BountySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceId])
}

model BountyTask {
  id          String   @id @default(cuid())
  sourceId    String
  externalId  String
  title       String
  url         String
  projectName String
  repo        String?
  amountText  String?
  amountMin   Int?
  amountMax   Int?
  currency    String   @default("USD")
  techTags    String   @default("[]")
  kind        String   @default("bounty")
  status      String   @default("open")
  summary     String?
  rawJson     String   @default("{}")
  fetchedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  source      BountySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  shortlists  Shortlist[]
  claims      TaskClaim[]
  activities  Activity[]

  @@unique([sourceId, externalId])
  @@index([status, amountMax])
  @@index([projectName])
}

model Shortlist {
  id         String     @id @default(cuid())
  userId     String
  taskId     String?
  projectKey String?
  note       String?
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  task       BountyTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@unique([userId, projectKey])
}

/// 认领：灵活就业者声明「我在做这单」，减少撞车
model TaskClaim {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  status    String   @default("working") // working | submitted | paid | dropped
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      BountyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([taskId, status])
}

/// 社区动态：凝聚协作氛围
model Activity {
  id        String   @id @default(cuid())
  userId    String
  taskId    String?
  type      String   // joined | claimed | shared | submitted | paid | tip
  message   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      BountyTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

/// 自报收益：灵活就业者记录实收，形成个人账本
model Earning {
  id          String   @id @default(cuid())
  userId      String
  title       String
  amountCents Int
  currency    String   @default("USD")
  projectName String?
  taskUrl     String?
  note        String?
  earnedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, earnedAt])
}
